datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id           String       @id @default(cuid())
  name         String
  taxId        String?
  vatId        String?
  address      String?
  web          String?
  email        String?
  phone        String?
  logoUrl      String?
  signatureUrl String?
  
  // Integrations
  cloudIntegrationGoogleDrive Boolean @default(false)
  googleDriveCredentials      String? // JSON string
  cloudIntegrationDropbox     Boolean @default(false)
  cloudIntegrationOneDrive    Boolean @default(false)
  googleCalendarIntegration   Boolean @default(false)
  notificationWebhookUrl      String?

  vatPayerStatus String      @default("NON_PAYER") // NON_PAYER, PAYER, IDENTIFIED_PERSON
  defaultVatMode String      @default("STANDARD")  // STANDARD, REVERSE_CHARGE, OSS

  // Settings
  isLegalHold        Boolean      @default(false)
  defaultGdprClause  String?
  defaultSlaText     String?
  christmasMode      Boolean      @default(false)
  
  // Phase 27: Formats
  numberFormat       String       @default("SPACE_COMMA") // "SPACE_COMMA" (1 000,00) or "COMMA_DOT" (1,000.00)
  timeFormat         String       @default("24h")         // "12h" or "24h"
  weekStart          String       @default("MONDAY")      // "MONDAY" or "SUNDAY"

  // Phase 30: Math
  roundingRule       String       @default("MATH_2")      // "MATH_2", "CEIL_0", "MATH_0"

  // Phase 31: SMTP
  smtpHost           String?
  smtpPort           Int?
  smtpUser           String?
  smtpPassword       String?      // Encrypted? Ideally yes.
  smtpFrom           String?

  // Phase 32: IMAP (Email Reading)
  imapHost           String?
  imapPort           Int?
  imapUser           String?
  imapPassword       String?
  imapEnabled        Boolean      @default(false)

  members      Membership[]
  auditLogs    AuditLog[]
  clients      Client[]
  invoices     Invoice[]
  bankDetails  BankDetail[]
  
  emailLogs      EmailLog[]
  bankIntegrations BankIntegration[]
  expenseCategories ExpenseCategory[]
  expenses       Expense[]
  recurringInvoices RecurringInvoice[]
  webhooks       Webhook[]
  apiKeys        ApiKey[]
  emergencyAccess EmergencyAccess[]
  taxRates       TaxRate[]
  
  // Phase 41-50
  projects       Project[]
  products       Product[]
  vehicles       Vehicle[]
  timeEntries    TimeEntry[]
  
  // Phase 51-60
  invoiceTemplates InvoiceTemplate[]
  customFields     CustomFieldDefinition[]
  roleDefinitions  RoleDefinition[] // Custom roles (RBAC)
  contracts        Contract[]
  clientTags       ClientTag[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model BankDetail {
  id             String       @id @default(cuid())
  organizationId String
  bankName       String
  accountNumber  String
  iban           String?
  swift          String?
  currency       String       @default("CZK")
  isDefault      Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id])
  invoices       Invoice[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isPinned       Boolean      @default(false)
}

// Phase 2: Clients40: Contracts
model Contract {
  id             String       @id @default(cuid())
  organizationId String
  clientId       String
  title          String
  validFrom      DateTime?
  validUntil     DateTime?
  fileUrl        String?
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  client         Client       @relation(fields: [clientId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Dispute {
  id             String       @id @default(cuid())
  invoiceId      String
  clientId       String
  message        String
  status         String       @default("OPEN") // OPEN, RESOLVED, REJECTED
  adminResponse  String?
  
  invoice        Invoice      @relation(fields: [invoiceId], references: [id])
  client         Client       @relation(fields: [clientId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  username     String?      @unique // New field for dual login
  passwordHash String
  firstName    String?
  lastName     String?
  avatarUrl    String?
  memberships  Membership[]
  auditLogs    AuditLog[]
  tasks        Task[]
  
  // Phase 41-50
  timeEntries    TimeEntry[]
  requestedApprovals ApprovalRequest[] @relation("RequestedApprovals")
  actionedApprovals  ApprovalRequest[] @relation("ActionedApprovals")

  // Phase 51-60
  impersonatedBy     ImpersonationLog[] @relation("ImpersonatedUser")
  impersonations     ImpersonationLog[] @relation("Impersonator")
  emergencyAccess    EmergencyAccess[]

  // Phase 61-70 Preparation
  accounts           Account[]
  twoFactorEnabled   Boolean      @default(false)
  twoFactorSecret    String?      // TOTP secret
  
  department         String?      // Department Isolation
  timezone           String?      // Timezone detection (e.g. "Europe/Prague")
  dashboardPreferences String?    // JSON string for widget visibility
  isBlocked          Boolean      @default(false)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model EmergencyAccess {
  id             String       @id @default(cuid())
  organizationId String
  userId         String       // The user who gets access
  targetRole     String       // The role they get (ADMIN)
  isPending      Boolean      @default(false)
  requestedAt    DateTime?
  grantedAt      DateTime?
  
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String
  expires DateTime

  @@unique([email, token])
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String // Enum Role handled in app
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  roleDefinition RoleDefinition? @relation(fields: [roleDefId], references: [id])
  roleDefId      String?      // Optional link to custom role

  expiresAt      DateTime?    // Time-limited access
  
  hourlyRate     Float?       // Default hourly rate for time tracking

  @@unique([userId, organizationId])
}

model RoleDefinition {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  permissions    String       // JSON string of permissions
  isSystem       Boolean      @default(false)
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  memberships    Membership[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
}

model ImpersonationLog {
  id             String       @id @default(cuid())
  impersonatorId String
  targetUserId   String
  reason         String?
  startedAt      DateTime     @default(now())
  endedAt        DateTime?
  
  impersonator   User         @relation("Impersonator", fields: [impersonatorId], references: [id])
  targetUser     User         @relation("ImpersonatedUser", fields: [targetUserId], references: [id])
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  taxId          String? // ICO
  vatId          String? // DIC
  address        String?
  city           String?
  zip            String?
  country        String?     @default("CZ")
  email          String?
  phone          String?
  language       String      @default("cs") // cs, en, de
  defaultDueDays Int          @default(14)
  defaultCurrency String      @default("CZK")
  organization   Organization @relation(fields: [organizationId], references: [id])
  invoices       Invoice[]
  
  emailLogs      EmailLog[]
  recurringInvoices RecurringInvoice[]
  
  // Phase 41-50
  projects       Project[]
  webAccess      Boolean      @default(false)
  accessCode     String?      // Simple code for client portal login
  establishedDate DateTime?   // Marketing: Anniversary / Birthday
  disputes       Dispute[]
  contracts      Contract[]
  tags           ClientTag[]
  contacts       Contact[]

  mailingAddress String?
  mailingCity    String?
  mailingZip     String?
  mailingCountry String?     @default("CZ")
  notes          String?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Contact {
  id             String       @id @default(cuid())
  clientId       String
  name           String
  email          String?
  phone          String?
  role           String?      // e.g. "CEO", "Accountant"
  isPrimary      Boolean      @default(false)
  
  client         Client       @relation(fields: [clientId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ClientTag {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  color          String?
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  clients        Client[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  @@unique([organizationId, name])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  clientId       String
  number         String        // Cislo faktury
  type           String        // FAKTURA, PROFORMA, NABIDKA
  status         String        // DRAFT, ISSUED, PAID, CANCELLED, PARTIAL
  paidAmount     Float         @default(0)
  issuedAt       DateTime      @default(now())
  dueAt          DateTime
  variableSymbol String?
  constantSymbol String?
  specificSymbol String?
  currency       String        @default("CZK")
  totalAmount    Float         @default(0)
  totalVat       Float         @default(0)
  overpaymentAmount Float      @default(0)
  notes          String?
  bankDetailId   String?
  
  department     String?      // Department Isolation

  // Phase 21-30 Extensions
  vatMode        String        @default("STANDARD") // STANDARD, REVERSE_CHARGE, OSS
  exchangeRate   Float         @default(1)
  discount       Float         @default(0) // Percentage discount
  totalDiscount  Float         @default(0) // Calculated total discount amount
  isLocked       Boolean       @default(false)
  isPinned       Boolean       @default(false)
  relatedId      String?       // For Credit Notes or converted documents
  
  organization   Organization  @relation(fields: [organizationId], references: [id])
  client         Client        @relation(fields: [clientId], references: [id])
  bankDetail     BankDetail?   @relation(fields: [bankDetailId], references: [id])
  items          InvoiceItem[]
  attachments    Attachment[]
  
  emailLogs      EmailLog[]
  bankMovements  BankMovement[]
  
  // Phase 41-50
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  approvalRequest ApprovalRequest?
  disputes        Dispute[]

  // Phase 51-60
  templateId     String?
  template       InvoiceTemplate? @relation(fields: [templateId], references: [id])
  customFields   InvoiceCustomFieldValue[]
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unit        String   @default("ks")
  unitPrice   Float
  vatRate     Float
  discount    Float    @default(0) // Percentage discount
  totalAmount Float
  sku         String?
  weightKg    Float?   @default(0)
  
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  invoiceId String
  fileName  String
  fileType  String
  fileUrl   String
  fileSize  Int
  createdAt DateTime @default(now())

  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  action         String
  entityId       String?
  oldData        String?      // JSON string
  newData        String?      // JSON string
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
}

// Phase 31-40 Extensions

model EmailLog {
  id             String       @id @default(cuid())
  organizationId String?      // Optional for now, but good practice
  invoiceId      String?
  clientId       String?
  subject        String
  body           String
  status         String       @default("SENT") // SENT, FAILED, OPENED
  sentAt         DateTime     @default(now())
  openedAt       DateTime?
  clickedAt      DateTime?    // First click time
  clickCount     Int          @default(0)
  messageId      String?
  recipient      String
  
  organization   Organization? @relation(fields: [organizationId], references: [id])
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])
}

model RecurringInvoice {
  id             String       @id @default(cuid())
  organizationId String
  clientId       String
  templateName   String
  cronExpression String       // e.g. "0 0 1 * *" for monthly
  nextRunAt      DateTime
  lastRunAt      DateTime?
  active         Boolean      @default(true)
  
  // Template data (JSON)
  invoiceData    String       
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  client         Client       @relation(fields: [clientId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model BankIntegration {
  id             String       @id @default(cuid())
  organizationId String
  provider       String       // FIO, RB
  encryptedToken String
  encryptedKey   String?      // For RB which might need cert/key
  isActive       Boolean      @default(true)
  lastSyncAt     DateTime?
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  movements      BankMovement[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model BankMovement {
  id             String       @id @default(cuid())
  bankIntegrationId String?
  invoiceId      String?      // Linked invoice
  
  transactionId  String       // Bank's ID
  amount         Float
  currency       String
  date           DateTime
  
  variableSymbol String?
  constantSymbol String?
  specificSymbol String?
  
  accountName    String?
  accountInfo    String?
  message        String?
  
  status         String       @default("UNMATCHED") // UNMATCHED, MATCHED, IGNORED, PROPOSED, PROPOSED_MULTI
  
  bankIntegration BankIntegration? @relation(fields: [bankIntegrationId], references: [id])
  invoice         Invoice?    @relation(fields: [invoiceId], references: [id])
  createdAt      DateTime     @default(now())
}

model ExpenseCategory {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  color          String?
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  expenses       Expense[]
}

model Expense {
  id             String       @id @default(cuid())
  organizationId String
  categoryId     String?
  
  description    String
  amount         Float
  currency       String       @default("CZK")
  date           DateTime
  
  supplierName   String?
  supplierId     String?      // ID or VAT ID
  
  receiptUrl     String?      // Image/PDF
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  category       ExpenseCategory? @relation(fields: [categoryId], references: [id])
  
  // Phase 41-50
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  
  isSubcontractorCost Boolean @default(false)
  possibleDuplicate   Boolean @default(false)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Phase 41-50 Extensions

model Project {
  id             String       @id @default(cuid())
  organizationId String
  clientId       String?
  name           String
  description    String?
  color          String?      @default("#000000")
  hourlyRate     Float?
  budget         Float?
  currency       String       @default("CZK")
  status         String       @default("ACTIVE") // ACTIVE, COMPLETED, ARCHIVED
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])
  timeEntries    TimeEntry[]
  invoices       Invoice[]
  expenses       Expense[]
  tasks          Task[]
  milestones     ProjectMilestone[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model TimeEntry {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  projectId      String?
  taskId         String?      // Optional task reference
  
  description    String
  startTime      DateTime
  endTime        DateTime?
  duration       Int?         // In seconds
  billable       Boolean      @default(true)
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  project        Project?     @relation(fields: [projectId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Product {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  sku            String?      // Stock Keeping Unit
  ean            String?      // Barcode
  unit           String       @default("ks")
  
  buyPrice       Float        @default(0)
  sellPrice      Float        @default(0)
  currency       String       @default("CZK")
  vatRate        Float        @default(21)
  
  stockQuantity  Float        @default(0)
  minStockLevel  Float        @default(0)
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  movements      StockMovement[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model StockMovement {
  id             String       @id @default(cuid())
  productId      String
  type           String       // IN, OUT
  quantity       Float
  date           DateTime     @default(now())
  note           String?
  
  product        Product      @relation(fields: [productId], references: [id])
  
  createdAt      DateTime     @default(now())
}

model Vehicle {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  plate          String
  fuelType       String?      // DIESEL, PETROL, ELECTRIC
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  logs           VehicleLog[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model VehicleLog {
  id             String       @id @default(cuid())
  vehicleId      String
  date           DateTime
  startKm        Float
  endKm          Float
  distance       Float
  purpose        String?
  from           String
  to             String
  
  vehicle        Vehicle      @relation(fields: [vehicleId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ApprovalRequest {
  id             String       @id @default(cuid())
  invoiceId      String       @unique
  requesterId    String
  approverId     String?      // Who actually approved it
  status         String       @default("PENDING") // PENDING, APPROVED, REJECTED
  note           String?
  
  invoice        Invoice      @relation(fields: [invoiceId], references: [id])
  requester      User         @relation("RequestedApprovals", fields: [requesterId], references: [id])
  approver       User?        @relation("ActionedApprovals", fields: [approverId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Phase 51-60 Extensions

model InvoiceTemplate {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  
  // Visual settings
  primaryColor   String       @default("#000000")
  secondaryColor String       @default("#ffffff")
  fontFamily     String       @default("Helvetica")
  customFontUrl  String?      // URL to custom font file (woff/woff2)
  logoPosition   String       @default("left") // left, center, right
  showQrCode     Boolean      @default(true)
  showSignature  Boolean      @default(true)
  showBarcodes   Boolean      @default(false)
  
  // Advanced customization
  customCss      String?      // For experts
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  invoices       Invoice[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model CustomFieldDefinition {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  key            String       // Machine readable key (e.g., "project_code")
  type           String       // TEXT, NUMBER, DATE, BOOLEAN
  description    String?
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  values         InvoiceCustomFieldValue[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model InvoiceCustomFieldValue {
  id             String                @id @default(cuid())
  invoiceId      String
  fieldId        String
  value          String                // Stored as string, cast based on definition type

  invoice        Invoice               @relation(fields: [invoiceId], references: [id])
  definition     CustomFieldDefinition @relation(fields: [fieldId], references: [id])

  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([invoiceId, fieldId])
}

model Task {
  id               String       @id @default(cuid())
  projectId        String
  title            String
  description      String?
  assignedToUserId String?
  dueDate          DateTime?
  status           String       @default("TODO") // TODO, IN_PROGRESS, DONE
  
  project          Project      @relation(fields: [projectId], references: [id])
  assignedTo       User?        @relation(fields: [assignedToUserId], references: [id])
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ProjectMilestone {
  id             String       @id @default(cuid())
  projectId      String
  title          String
  amount         Float        @default(0)
  dueDate        DateTime?
  isCompleted    Boolean      @default(false)
  isBilled       Boolean      @default(false)
  
  project        Project      @relation(fields: [projectId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Webhook {
  id             String       @id @default(cuid())
  organizationId String
  targetUrl      String
  secretKey      String?
  eventTypes     String       // Comma separated list of events
  isActive       Boolean      @default(true)
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  logs           WebhookLog[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model WebhookLog {
  id                 String       @id @default(cuid())
  webhookId          String
  event              String
  requestPayload     String
  responseStatusCode Int
  responseBody       String?
  
  webhook            Webhook      @relation(fields: [webhookId], references: [id])
  
  createdAt          DateTime     @default(now())
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  keyPrefix      String
  keyHash        String
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model GlobalAnnouncement {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("INFO") // INFO, WARNING, ERROR
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 30: Math
model TaxRate {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  percentage     Float
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
